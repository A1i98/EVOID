---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';
import DocsSidebar from '../../components/docs/DocsSidebar.astro';
import DocsTOC from '../../components/docs/DocsTOC.astro';
import DocsNav from '../../components/docs/DocsNav.astro';
import DocsSearch from '../../components/docs/DocsSearch.astro';
import '../../styles/docs.css';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map((doc) => ({
    params: { slug: doc.id },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const { Content, headings } = await render(doc);

const slug = doc.id;
const section = slug.split('/')[0];
const navLinks = section === 'tutorial'
  ? [
      { label: 'Getting Started', href: '/docs/getting-started/installation/' },
      { label: 'Learn', href: '/docs/learn/intent/' },
      { label: 'Tutorial', href: '/docs/tutorial/first-steps/', active: true },
    ]
  : section === 'learn'
  ? [
      { label: 'Getting Started', href: '/docs/getting-started/installation/' },
      { label: 'Learn', href: '/docs/learn/intent/', active: true },
      { label: 'Tutorial', href: '/docs/tutorial/first-steps/' },
    ]
  : [
      { label: 'Getting Started', href: '/docs/getting-started/installation/', active: true },
      { label: 'Learn', href: '/docs/learn/intent/' },
      { label: 'Tutorial', href: '/docs/tutorial/first-steps/' },
    ];
---

<DocsLayout title={`${doc.data.title} — EVOID`} description={doc.data.description}>
  <!-- Docs Navbar -->
  <nav class="docs-navbar">
    <div class="docs-navbar-inner">
      <div class="docs-nav-left">
        <button class="docs-hamburger" id="docs-hamburger" aria-label="Open menu">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
        </button>
        {navLinks.map((link) => (
          <a href={link.href} class={`docs-nav-link-item ${link.active ? 'active' : ''}`}>{link.label}</a>
        ))}
      </div>

      <a href="/" class="docs-nav-logo">
        <span class="logo-text">evo</span>
      </a>

      <div class="docs-nav-right">
        <button class="docs-search-btn" id="docs-search-btn" aria-label="Search">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <span>Search</span>
          <kbd>⌘K</kbd>
        </button>
        <a href="https://github.com/EvolveBeyond/EVOID" target="_blank" rel="noopener" class="docs-nav-github" aria-label="GitHub">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
        <button class="docs-theme-toggle" id="docs-theme-toggle" aria-label="Toggle theme">
          <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
      </div>
    </div>
  </nav>

  <DocsSearch />

  <div class="docs-layout">
    <DocsSidebar currentSlug={doc.id} />

    <main class="docs-content">
      <article class="docs-article">
        <Content />
      </article>
      <DocsNav currentSlug={doc.id} />
    </main>

    <DocsTOC headings={headings} />
  </div>

  <style>
    .docs-navbar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: 60px;
      background: oklch(from var(--bg) l c h / 0.7);
      backdrop-filter: blur(16px) saturate(1.3);
      -webkit-backdrop-filter: blur(16px) saturate(1.3);
      border-bottom: 1px solid oklch(from var(--border) l c h / 0.4);
      z-index: 100;
      box-shadow: 0 1px 3px oklch(0 0 0 / 0.06), 0 4px 12px oklch(0 0 0 / 0.04);
    }
    .docs-navbar-inner {
      max-width: 100%;
      height: 100%;
      padding: 0 1.25rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .docs-nav-left {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex: 1;
    }
    .docs-hamburger {
      display: none;
      background: none;
      border: none;
      color: var(--text-muted);
      cursor: pointer;
      padding: 4px;
      border-radius: 6px;
    }
    .docs-hamburger:hover { color: var(--text); }
    .docs-nav-logo {
      text-decoration: none;
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
    }
    .docs-nav-logo .logo-text {
      font-family: 'JetBrainsMono Nerd Font', monospace;
      font-weight: 900;
      font-size: 1.5rem;
      color: var(--purple);
      text-shadow: 0 1px 2px oklch(0 0 0 / 0.1), 0 0 16px oklch(from var(--purple-glow) l c h / 0.3);
      letter-spacing: -0.03em;
      transition: text-shadow 0.2s ease;
    }
    .docs-nav-logo:hover .logo-text {
      text-shadow: 0 1px 2px oklch(0 0 0 / 0.1), 0 0 24px oklch(from var(--purple-glow) l c h / 0.5);
    }
    .docs-nav-right {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      flex: 1;
      justify-content: flex-end;
    }
    .docs-nav-link-item {
      font-size: 0.82rem;
      font-weight: 500;
      color: var(--text-muted);
      text-decoration: none;
      transition: color 0.15s ease;
    }
    .docs-nav-link-item:hover { color: var(--purple); }
    .docs-nav-link-item.active {
      color: var(--purple);
      font-weight: 600;
    }
    .docs-search-btn {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.35rem 0.7rem;
      border-radius: 8px;
      border: 1px solid oklch(from var(--border) l c h / 0.5);
      background: oklch(from var(--bg-tile) l c h / 0.6);
      color: var(--text-muted);
      font-size: 0.78rem;
      font-family: inherit;
      cursor: pointer;
      transition: all 0.15s ease;
    }
    .docs-search-btn:hover {
      border-color: var(--purple);
      color: var(--purple);
    }
    .docs-search-btn kbd {
      padding: 1px 4px;
      border-radius: 3px;
      background: oklch(from var(--border) l c h / 0.5);
      font-size: 0.6rem;
      font-family: 'JetBrainsMono Nerd Font', monospace;
    }
    .docs-nav-github {
      color: var(--text-muted);
      display: flex;
      transition: color 0.15s ease;
    }
    .docs-nav-github:hover { color: var(--text); }
    .docs-theme-toggle {
      width: 30px;
      height: 30px;
      border-radius: 8px;
      border: 1px solid oklch(from var(--border) l c h / 0.4);
      background: oklch(from var(--bg-tile) l c h / 0.4);
      color: var(--text-muted);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.15s ease;
    }
    .docs-theme-toggle:hover { border-color: var(--purple); color: var(--purple); }
    .icon-moon { display: none; }
    [data-theme="dark"] .icon-sun { display: none; }
    [data-theme="dark"] .icon-moon { display: block; }
    @media (max-width: 768px) {
      .docs-hamburger { display: flex; }
      .docs-nav-link-item { display: none; }
      .docs-search-btn span { display: none; }
    }
  </style>

  <script>
    // Hamburger menu
    document.getElementById('docs-hamburger')?.addEventListener('click', () => {
      document.getElementById('docs-sidebar')?.classList.toggle('open');
      document.getElementById('sidebar-overlay')?.classList.toggle('open');
    });
    document.getElementById('sidebar-overlay')?.addEventListener('click', () => {
      document.getElementById('docs-sidebar')?.classList.remove('open');
      document.getElementById('sidebar-overlay')?.classList.remove('open');
    });

    // Theme toggle
    document.getElementById('docs-theme-toggle')?.addEventListener('click', () => {
      const html = document.documentElement;
      const current = html.getAttribute('data-theme');
      const next = current === 'dark' ? 'light' : 'dark';
      html.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
    });
  </script>
</DocsLayout>
