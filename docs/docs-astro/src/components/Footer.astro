<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <span class="footer-logo">evoid</span>
      <span class="footer-copy">&copy; 2026 EvolveBeyond</span>
    </div>
    <div class="footer-links">
      <a href="https://github.com/EvolveBeyond/EVOID">GitHub</a>
      <a href="https://pypi.org/project/evoid/">PyPI</a>
      <a href="/EVOID/docs/api/">API</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid oklch(from var(--border) l c h / 0.3);
    padding: 1.5rem 1.5rem;
  }
  .footer-inner {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .footer-brand {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .footer-logo {
    font-family: 'JetBrainsMono Nerd Font', monospace;
    font-weight: 800;
    font-size: 0.9rem;
    color: var(--purple);
  }
  .footer-copy {
    font-size: 0.78rem;
    color: var(--text-muted);
  }
  .footer-links {
    display: flex;
    gap: 1.5rem;
  }
  .footer-links a {
    font-size: 0.82rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .footer-links a:hover { color: var(--purple); }
</style>
