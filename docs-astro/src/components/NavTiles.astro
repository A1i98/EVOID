---
const tiles = [
  { title: '@route', desc: 'Function decorators. FastAPI / Flask style.', href: '/docs/styles/route/', color: 'var(--purple)' },
  { title: '@controller', desc: 'Class-based routing. NestJS / Django REST.', href: '/docs/styles/controller/', color: 'var(--emerald)' },
  { title: 'Native', desc: 'Full control. Explicit Intent API.', href: '/docs/styles/native/', color: 'var(--purple-glow)' },
  { title: 'Tutorial', desc: 'Step-by-step from zero to production.', href: '/docs/tutorial/first-steps/', color: 'var(--purple)' },
  { title: 'API Reference', desc: 'Complete API docs for every module.', href: '/docs/api/', color: 'var(--emerald)' },
  { title: 'Examples', desc: 'Working code samples for every feature.', href: '/docs/examples/', color: 'var(--purple-glow)' },
];
---

<div class="nav-tiles-grid">
  {tiles.map((t) => (
    <a href={t.href} class="nav-tile">
      <div class="nav-tile-glow" style={`background: ${t.color}`}></div>
      <h3>{t.title}</h3>
      <p>{t.desc}</p>
      <span class="nav-tile-arrow">→</span>
    </a>
  ))}
</div>

<style>
  .nav-tiles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: oklch(from var(--border) l c h / 0.2);
  }

  .nav-tile {
    position: relative;
    background: oklch(from var(--bg) l c h / 0.45);
    backdrop-filter: blur(12px) saturate(1.2);
    -webkit-backdrop-filter: blur(12px) saturate(1.2);
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
    overflow: hidden;
  }
  .nav-tile::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, oklch(1 0 0 / 0.08) 50%, transparent 100%);
    pointer-events: none;
  }
  .nav-tile:hover {
    background: oklch(from var(--bg) l c h / 0.6);
  }

  .nav-tile-glow {
    position: absolute;
    top: -20px;
    right: -20px;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    filter: blur(30px);
    opacity: 0.15;
    transition: opacity 0.2s ease;
  }
  .nav-tile:hover .nav-tile-glow { opacity: 0.3; }

  .nav-tile h3 {
    font-size: 0.9rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
    font-family: 'JetBrainsMono Nerd Font', monospace;
  }
  .nav-tile p {
    font-size: 0.78rem;
    color: var(--text-muted);
    line-height: 1.5;
  }
  .nav-tile-arrow {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    font-size: 1rem;
    color: var(--text-muted);
    transition: color 0.2s ease, transform 0.2s ease;
  }
  .nav-tile:hover .nav-tile-arrow {
    color: var(--purple);
    transform: translateX(3px);
  }

  @media (max-width: 768px) {
    .nav-tiles-grid { grid-template-columns: 1fr; }
  }
  @media (min-width: 769px) and (max-width: 1024px) {
    .nav-tiles-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
